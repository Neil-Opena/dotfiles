{
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "permissions": {
    "deny": [
      "**/node_modules/**",
      "**/.expo/**",
      "**/.expo-shared/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/out/**",
      "**/coverage/**",
      "**/.nyc_output/**",
      "**/ios/Pods/**",
      "**/ios/build/**",
      "**/ios/DerivedData/**",
      "**/android/build/**",
      "**/android/.gradle/**",
      "**/android/app/build/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/*.egg-info/**",
      "**/target/**",
      "**/vendor/**"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/neilopena/.nvm/versions/node/v24.11.0/bin/node\" \"/Users/neilopena/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/neilopena/.nvm/versions/node/v24.11.0/bin/node\" \"/Users/neilopena/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "expo@expo-plugins": true,
    "document-skills@anthropic-agent-skills": false,
    "figma@claude-plugins-official": false,
    "warp@claude-code-warp": true,
    "caveman@caveman": true
  }
}
